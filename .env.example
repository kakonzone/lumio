# Lumio monetization — copy to .env (gitignored) and `source .env` before builds.
# Never commit real values. See docs/SECRETS.md and docs/SECRETS_MIGRATION.md.

# ── Required for release APK (tool/build_release_apk.sh) ─────────────────────
LEVELPLAY_APP_KEY=
LEVELPLAY_INTERSTITIAL_AD_UNIT=
LEVELPLAY_BANNER_AD_UNIT=
CAP_BASE_URL=
CAP_HMAC_KEY=

# Adsterra — at least one surface (direct link OR a script+base pair)
ADSTERRA_DIRECT_LINK=
# ADSTERRA_POPUNDER_SCRIPT_URL=
# ADSTERRA_POPUNDER_BASE_URL=
# ADSTERRA_NATIVE_INVOKE_URL=
# ADSTERRA_NATIVE_BASE_URL=
# ADSTERRA_BANNER728_INVOKE_URL=
# ADSTERRA_BANNER728_BASE_URL=

# ── Debug QA (non-release) ───────────────────────────────────────────────────
# ADS_ENABLED=true

# ── Optional ─────────────────────────────────────────────────────────────────
# ADSTERRA_SMARTLINK_URL=
# ADSTERRA_SOCIAL_SCRIPT_URL=
# ADSTERRA_SOCIAL_BASE_URL=
# ADSTERRA_NATIVE_CONTAINER_ID=
# ADSTERRA_BANNER728_CONTAINER_ID=
# ADSTERRA_TELEMETRY_URL=
# ADSTERRA_TELEMETRY_HMAC_KEY=
# FINGERPRINT_MIGRATION_SALT=
# ADS_TEST_MODE=true
