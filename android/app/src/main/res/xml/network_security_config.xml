<?xml version="1.0" encoding="utf-8"?>
<!-- Lumio: HTTPS-by-default; minimal cleartext exceptions for legacy IPTV streams only. -->
<network-security-config>
    <!-- Base config: HTTPS required everywhere -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors><certificates src="system" /></trust-anchors>
    </base-config>

    <!-- Known HTTPS-only services (explicit allowlist for clarity) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">app-measurement.com</domain>
        <domain includeSubdomains="true">applovin.com</domain>
        <domain includeSubdomains="true">applvn.com</domain>
        <domain includeSubdomains="true">effectivecpmnetwork.com</domain>
        <domain includeSubdomains="true">fcm.googleapis.com</domain>
        <domain includeSubdomains="true">fcmtoken.googleapis.com</domain>
        <domain includeSubdomains="true">firebase.googleapis.com</domain>
        <domain includeSubdomains="true">firebaseinstallations.googleapis.com</domain>
        <domain includeSubdomains="true">firebaselogging.googleapis.com</domain>
        <domain includeSubdomains="true">firebaseremoteconfig.googleapis.com</domain>
        <domain includeSubdomains="true">google-analytics.com</domain>
        <domain includeSubdomains="true">google.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">gstatic.com</domain>
        <domain includeSubdomains="true">highperformanceformat.com</domain>
        <domain includeSubdomains="true">ironsource.mobi</domain>
        <domain includeSubdomains="true">isprog.com</domain>
        <domain includeSubdomains="true">supersonicads.com</domain>
        <domain includeSubdomains="true">unity3d.com</domain>
        <domain includeSubdomains="true">www.google.com</domain>
    </domain-config>

    <!-- Debug-only: Local development (NOT for production) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
        <!-- Android emulator loopback -->
        <domain-config cleartextTrafficPermitted="true">
            <domain includeSubdomains="true">10.0.2.2</domain>
            <domain includeSubdomains="true">localhost</domain>
            <!-- Environment placeholders for local development -->
            <domain includeSubdomains="true">$envHost</domain>
        </domain-config>
    </debug-overrides>

    <!-- Minimal production cleartext exceptions (documented) -->
    <!-- Each exception has a documented reason and should be migrated to HTTPS -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- JioTV scan server (legacy IPTV - no HTTPS available) -->
        <domain includeSubdomains="true">103.180.212.191</domain>
        
        <!-- Scan playlist server (legacy IPTV - no HTTPS available) -->
        <domain includeSubdomains="true">202.70.146.135</domain>

        <!-- Issue: These domains have HTTP-only streams that need HTTPS migration -->
        <!-- TODO: Each of these should be probed weekly and migrated to HTTPS or proxied -->
        <domain includeSubdomains="true">2-fss-2.streamhoster.com</domain>
        <domain includeSubdomains="true">5bf7b725107e5.streamlock.net</domain>
        <domain includeSubdomains="true">60417ddeaf0d9.streamlock.net</domain>
        <domain includeSubdomains="true">627bb251f23c7.streamlock.net</domain>
        <domain includeSubdomains="true">a-edge.bliscdn.com</domain>
        <domain includeSubdomains="true">alvetv.com</domain>
        <domain includeSubdomains="true">banglajagotv.livebox.co.in</domain>
        <domain includeSubdomains="true">cdn.live247stream.com</domain>
        <domain includeSubdomains="true">cdn.streamcast.xyz</domain>
        <domain includeSubdomains="true">cdntv.online</domain>
        <domain includeSubdomains="true">filex.me</domain>
        <domain includeSubdomains="true">footystream.pk</domain>
        <domain includeSubdomains="true">hksk.dataplayer.in</domain>
        <domain includeSubdomains="true">hlsb-us.god.tv</domain>
        <domain includeSubdomains="true">iptv.prosto.tv</domain>
        <domain includeSubdomains="true">istream.binarywaves.com</domain>
        <domain includeSubdomains="true">live-stream.amarbanglatv.in</domain>
        <domain includeSubdomains="true">live.dataplayer.in</domain>
        <domain includeSubdomains="true">livelegitpro.in</domain>
        <domain includeSubdomains="true">stream.pardesitv.online</domain>
        <domain includeSubdomains="true">tv.tuva.ru</domain>
        <domain includeSubdomains="true">unlimited6-cl.dps.live</domain>
        <domain includeSubdomains="true">wo0dyefk.dienalt.org</domain>
        <domain includeSubdomains="true">y3fqd48g.megatv.fun</domain>
    </domain-config>

    <!-- Debug-only: Local development (NOT for production) -->
    <debug-overrides>
        <base-config cleartextTrafficPermitted="true">
            <trust-anchors>
                <certificates src="system" />
                <certificates src="user" />
            </trust-anchors>
            <!-- Allow localhost in debug builds for development -->
            <domain-config cleartextTrafficPermitted="true">
                <domain includeSubdomains="true">localhost</domain>
                <domain includeSubdomains="true">127.0.0.1</domain>
            </domain-config>
        </base-config>
    </debug-overrides>
</network-security-config>
