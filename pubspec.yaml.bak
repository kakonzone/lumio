name: lumio_tv
description: Lumio TV - Live Streaming App
version: 1.0.0+1
publish_to: 'none'

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  # HTTP
  http: ^1.2.1
  dio: ^5.4.3+1
  # State management
  provider: ^6.1.2
  # Video player
  better_player: ^0.0.84
  # Cached images
  cached_network_image: ^3.3.1
  # Icons
  flutter_svg: ^2.0.10+1
  # Storage
  shared_preferences: ^2.2.3
  # Pull to refresh
  pull_to_refresh: ^2.0.0
  # Shimmer loading
  shimmer: ^3.0.0
  # URL launcher
  url_launcher: ^6.3.0
  # Connectivity
  connectivity_plus: ^6.0.3
  # Lottie animations
  lottie: ^3.1.0

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^4.0.0

flutter:
  uses-material-design: true
  assets:
    - assets/images/
    - assets/icons/
  fonts:
    - family: Barlow
      fonts:
        - asset: assets/fonts/Barlow-Regular.ttf
        - asset: assets/fonts/Barlow-Medium.ttf
          weight: 500
        - asset: assets/fonts/Barlow-Bold.ttf
          weight: 700
        - asset: assets/fonts/Barlow-ExtraBold.ttf
          weight: 800
    - family: BarlowCondensed
      fonts:
        - asset: assets/fonts/BarlowCondensed-Bold.ttf
          weight: 700
        - asset: assets/fonts/BarlowCondensed-ExtraBold.ttf
          weight: 800